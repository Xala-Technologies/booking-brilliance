</section>

<style>
  .dg-hero {
    position: relative;
    padding-block: 0.75rem 1.5rem;
    isolation: isolate;
  }

  @media (min-width: 64em) {
    .dg-hero { padding-block: 1rem 2rem; }
  }

  .dg-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    padding-block-start: 0.5rem;
  }

  @media (min-width: 64em) {
    .dg-hero__grid {
      /* Asymmetric 8-4 spread — main story takes 8 cols, rail 4 */
      grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
      gap: 3.5rem;
    }
  }

  .dg-hero__rubric {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: hsl(var(--accent-text));
    margin: 0 0 1.25rem;
    padding-block: 0.4rem;
    padding-inline: 0.7rem;
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 1px;
    line-height: 1;
  }

  .dg-hero__rubric-sep {
    display: inline-block;
    width: 1px;
    height: 0.7rem;
    background: hsl(var(--rule-strong));
    margin-inline: 0.15rem;
  }

  .dg-hero__rubric-meta {
    color: hsl(var(--ink-faint));
    font-feature-settings: "tnum" 1;
  }

  .dg-hero__pilcrow {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 24, "wght" 700, "SOFT" 0, "WONK" 1;
    font-size: 0.95rem;
    line-height: 0;
    color: hsl(var(--accent-text));
  }

  .dg-hero__h1 {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    /* WONK axis on — gives the serifs character, just like the marketing
     * Navbar wordmark. Heavier wght for impact at display size. */
    font-variation-settings: "opsz" 144, "wght" 500, "SOFT" 25, "WONK" 1;
    font-size: clamp(2.75rem, 7.5vw + 0.5rem, 6.5rem);
    line-height: 0.96;
    letter-spacing: -0.03em;
    color: hsl(var(--ink));
    margin: 0;
    text-wrap: balance;
    max-width: 14ch;
  }

  .dg-hero__dash {
    width: 3rem;
    height: 2px;
    background: hsl(var(--ink));
    margin-block: 1rem 0.85rem;
  }

  .dg-hero__lede {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 24, "wght" 380, "SOFT" 50, "WONK" 0;
    font-style: italic;
    font-size: clamp(1.1rem, 0.9vw + 0.95rem, 1.4rem);
    line-height: 1.45;
    color: hsl(var(--ink-soft));
    margin: 0;
    max-width: 38ch;
  }

  /* CTA buttons — newspaper "section jump" treatment */
  .dg-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-start: 1.5rem;
  }

  .dg-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.25rem;
    color: hsl(var(--ink));
    background: transparent;
    border: 0.5px solid hsl(var(--ink));
    border-radius: 2px;
    transition: background 200ms var(--ease-editorial), color 200ms var(--ease-editorial);
  }

  .dg-hero__btn:hover {
    background: hsl(var(--ink));
    color: hsl(var(--paper));
  }

  .dg-hero__btn--primary {
    background: hsl(var(--navy));
    color: hsl(var(--on-navy));
    border-color: hsl(var(--navy));
  }

  .dg-hero__btn--primary:hover {
    background: hsl(var(--paper));
    color: hsl(var(--navy));
  }

  .dg-hero__btn-num {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 14, "wght" 600, "SOFT" 0, "WONK" 1;
    font-size: 0.9rem;
    line-height: 1;
  }

  /* Editorial stats strip — three plant-of-the-month-style numbers */
  .dg-hero__stats {
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: hsl(var(--rule));
    border-block: 1px solid hsl(var(--rule));
  }

  .dg-hero__stats li {
    background: hsl(var(--paper));
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .dg-hero__stat-num {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 72, "wght" 500, "SOFT" 25, "WONK" 1;
    font-size: 2.25rem;
    line-height: 1;
    color: hsl(var(--ink));
  }

  .dg-hero__stat-num small {
    font-size: 1rem;
    color: hsl(var(--ink-faint));
    margin-inline-start: 0.1rem;
  }

  .dg-hero__stat-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(var(--ink-faint));
  }

  /* ── Mest leste — fills space below the stats strip ─────── */
  .dg-hero__popular {
    margin-block-start: 2rem;
    padding-block-start: 1.5rem;
    border-block-start: 1px solid hsl(var(--rule));
  }

  .dg-hero__popular-head {
    margin-block-end: 1.1rem;
  }

  .dg-hero__popular-kicker {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(var(--accent-text));
    font-weight: 600;
    margin: 0 0 0.4rem;
  }

  .dg-hero__popular-title {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 48, "wght" 460, "SOFT" 30, "WONK" 0;
    font-style: italic;
    font-size: 1.6rem;
    line-height: 1.2;
    color: hsl(var(--ink));
    margin: 0;
  }

  .dg-hero__popular-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .dg-hero__popular-list a {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    gap: 1.1rem;
    align-items: baseline;
    padding-block: 0.95rem;
    border-block-end: 0.5px solid hsl(var(--rule));
    text-decoration: none;
    color: inherit;
    transition: padding-inline-start 180ms var(--ease-editorial);
  }

  .dg-hero__popular-list li:last-child a {
    border-block-end: 0;
  }

  .dg-hero__popular-list a:hover {
    padding-inline-start: 0.5rem;
  }

  .dg-hero__popular-num {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: hsl(var(--accent-text));
  }

  .dg-hero__popular-body {
    display: grid;
    grid-template-rows: auto auto;
    gap: 0.25rem;
  }

  .dg-hero__popular-body strong {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 36, "wght" 540, "SOFT" 30, "WONK" 0;
    font-weight: normal;
    font-size: 1.1rem;
    color: hsl(var(--ink));
    line-height: 1.2;
  }

  .dg-hero__popular-body small {
    font-size: 0.85rem;
    color: hsl(var(--ink-soft));
  }

  .dg-hero__popular-time {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: hsl(var(--ink-faint));
    align-self: center;
  }

  /* Rail — printed-book "index" with leader dots */
  .dg-hero__rail {
    border-inline-start: 0.5px solid hsl(var(--rule-strong));
    padding-inline-start: 1.5rem;
    align-self: start;
  }

  @media (max-width: 63.99em) {
    .dg-hero__rail {
      border-inline-start: 0;
      padding-inline-start: 0;
      border-block-start: 1px solid hsl(var(--rule));
      padding-block-start: 1.5rem;
    }
  }

  .dg-hero__rail-caption {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: hsl(var(--ink-faint));
    margin: 0 0 1.1rem;
  }

  .dg-hero__rail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .dg-hero__rail-list a {
    display: grid;
    grid-template-columns: 2.25rem 1fr;
    gap: 0.85rem;
    align-items: baseline;
    padding-block: 0.85rem;
    border-block-end: 1px solid hsl(var(--rule));
    text-decoration: none;
    color: inherit;
    transition: padding-inline-start 200ms var(--ease-editorial);
  }

  .dg-hero__rail-list li:last-child a { border-block-end: 0; }

  .dg-hero__rail-list a:hover { padding-inline-start: 0.4rem; }

  .dg-hero__rail-num {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 36, "wght" 460, "SOFT" 30, "WONK" 1;
    font-style: italic;
    font-size: 1.4rem;
    line-height: 1;
    color: hsl(var(--accent-text));
    text-align: end;
  }

  .dg-hero__rail-body {
    display: grid;
    grid-template-rows: auto auto;
  }

  .dg-hero__rail-body strong {
    font-family: "Fraunces", "Iowan Old Style", Georgia, serif;
    font-variation-settings: "opsz" 36, "wght" 540, "SOFT" 30, "WONK" 0;
    font-weight: normal;
    font-size: 1.15rem;
    color: hsl(var(--ink));
    line-height: 1.15;
    position: relative;
    overflow: hidden;
  }

  /* Leader dots after the title — classic printed-book "Index" feel */
  .dg-hero__rail-dots {
    display: none;
  }

  .dg-hero__rail-body small {
    font-size: 0.78rem;
    color: hsl(var(--ink-faint));
    margin-block-start: 0.2rem;
