        <span>SATT I FRAUNCES &amp; PUBLIC SANS</span>
      </p>
    </aside>
  </div>

  <div class="dg-hero__ornament" aria-hidden="true">
    <span class="dg-hero__ornament-rule"></span>
    <span class="dg-hero__ornament-mark">✦</span>
    <span class="dg-hero__ornament-rule"></span>
