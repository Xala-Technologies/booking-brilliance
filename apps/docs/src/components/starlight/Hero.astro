---
/**
 * Broadsheet hero — full-bleed editorial front page.
 *
 * Composition:
 *   ── MASTHEAD (Digilist · Vol · Issue · City · Date) ──
 *
 *      §                            [section directory rail]
 *      ┌─────────────────────────┐  ┌─────────────────────┐
 *      │  DEPARTEMENT-CAPTION    │  │  01  Kom i gang     │
 *      │                         │  │  02  Admin          │
 *      │  Massive Fraunces       │  │  03  API            │
 *      │  display headline       │  │  04  Compliance     │
 *      │  with WONK axis turned  │  └─────────────────────┘
 *      │  up for character       │
 *      │                         │
 *      │  Italic Fraunces lede   │
 *      │                         │
 *      │  [ KOM I GANG → ]       │
 *      └─────────────────────────┘
 *
 *   ── ornamental rule ✦ ──────────────────────────────────
 */
import type { Props } from "@astrojs/starlight/props";

const { entry } = Astro.props;
const data = entry.data;
const hero = data.hero;
const title = hero?.title ?? data.title;
const tagline = hero?.tagline ?? data.description ?? "";
const actions = hero?.actions ?? [];

// Compute volume/issue/date for the inline meta (folded into the rubric
// pill below — no separate masthead bar that would read as a 2nd header).
const now = new Date();
const year = now.getFullYear();
function isoWeek(date: Date): number {
  const tmp = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
  const day = tmp.getUTCDay() || 7;
  tmp.setUTCDate(tmp.getUTCDate() + 4 - day);
  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));
  return Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86_400_000 + 1) / 7);
}
const issue = String(isoWeek(now)).padStart(2, "0");
const dateShort = now.toLocaleDateString("nb-NO", { day: "numeric", month: "short" });
---

<section class="dg-hero">
  <div class="dg-hero__grid">
    <div class="dg-hero__main">
      <p class="dg-hero__rubric">
        <span class="dg-hero__pilcrow" aria-hidden="true">§</span>
        <span>DEPARTEMENT · DOKUMENTASJON</span>
        <span class="dg-hero__rubric-sep" aria-hidden="true"></span>
        <span class="dg-hero__rubric-meta">VOL. {year} · UTGAVE {issue} · {dateShort.toUpperCase()}</span>
      </p>
      <h1 class="dg-hero__h1">{title}</h1>
      <div class="dg-hero__dash" aria-hidden="true"></div>
      <p class="dg-hero__lede">
        <em>{tagline}</em>
      </p>

      {actions.length > 0 && (
        <div class="dg-hero__actions">
          {actions.map((a: { text: string; link: string; variant?: string }) => (
            <a
              href={a.link}
              class={`dg-hero__btn ${a.variant === "primary" ? "dg-hero__btn--primary" : ""}`}
            >
              <span class="dg-hero__btn-num" aria-hidden="true">→</span>
              <span>{a.text}</span>
            </a>
          ))}
        </div>
      )}

      <ul class="dg-hero__stats" aria-label="Plattformfakta">
        <li>
          <span class="dg-hero__stat-num">94<small>s</small></span>
          <span class="dg-hero__stat-label">Median booking-tid</span>
        </li>
        <li>
          <span class="dg-hero__stat-num">7</span>
          <span class="dg-hero__stat-label">Overflater overvåket</span>
        </li>
        <li>
          <span class="dg-hero__stat-num">100<small>%</small></span>
          <span class="dg-hero__stat-label">EØS-data-lokasjon</span>
        </li>
      </ul>

      <section class="dg-hero__popular" aria-labelledby="dg-popular-heading">
        <header class="dg-hero__popular-head">
          <p class="dg-hero__popular-kicker">MEST LESTE</p>
          <h2 class="dg-hero__popular-title" id="dg-popular-heading">
            <em>Hva andre leser akkurat nå</em>
          </h2>
        </header>
        <ul class="dg-hero__popular-list">
          <li>
            <a href="/kom-i-gang/innbygger/">
              <span class="dg-hero__popular-num">01</span>
              <span class="dg-hero__popular-body">
                <strong>Booking på 90 sekunder</strong>
                <small>Innbyggerens reise — søk, betal, bekreft</small>
              </span>
              <span class="dg-hero__popular-time">5 min</span>
            </a>
          </li>
          <li>
            <a href="/compliance/ssa-l/">
              <span class="dg-hero__popular-num">02</span>
              <span class="dg-hero__popular-body">
                <strong>SSA-L 2026 bilag 7</strong>
                <small>Samsvarsmatrise mot alle 18 sikkerhetskrav</small>
              </span>
              <span class="dg-hero__popular-time">6 min</span>
            </a>
          </li>
          <li>
            <a href="/admin/vekst/">
              <span class="dg-hero__popular-num">03</span>
              <span class="dg-hero__popular-body">
                <strong>Vekst-harness</strong>
                <small>Multi-agent system: keywords → drafts → publish</small>
              </span>
              <span class="dg-hero__popular-time">8 min</span>
            </a>
          </li>
        </ul>
      </section>
    </div>

    <aside class="dg-hero__rail" aria-label="Innholdsfortegnelse">
      <p class="dg-hero__rail-caption">INNHOLD · UTGAVE {issue}</p>
      <ol class="dg-hero__rail-list">
        <li>
          <a href="/kom-i-gang/">
            <span class="dg-hero__rail-num">I</span>
            <span class="dg-hero__rail-body">
              <strong>Kom i gang</strong>
              <small>Innbygger · Saksbehandler · Driftsleder</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">3 kapitler</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>≈ 18 min</span>
              </span>
            </span>
          </a>
        </li>
        <li>
          <a href="/arkitektur/">
            <span class="dg-hero__rail-num">II</span>
            <span class="dg-hero__rail-body">
              <strong>Arkitektur</strong>
              <small>Tre-plan-design · 27 komponenter · hendelse-buss</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">4 kapitler</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>≈ 38 min</span>
              </span>
            </span>
          </a>
        </li>
        <li>
          <a href="/integrasjoner/">
            <span class="dg-hero__rail-num">III</span>
            <span class="dg-hero__rail-body">
              <strong>Integrasjoner</strong>
              <small>ID-porten · Vipps · Stripe · EHF</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">5 oppsett</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>≈ 42 min</span>
              </span>
            </span>
          </a>
        </li>
        <li>
          <a href="/utvikling/">
            <span class="dg-hero__rail-num">IV</span>
            <span class="dg-hero__rail-body">
              <strong>Utvikling</strong>
              <small>Kom i gang · SDK · hooks · konvensjoner</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">2 kapitler</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>≈ 22 min</span>
              </span>
            </span>
          </a>
        </li>
        <li>
          <a href="/admin/">
            <span class="dg-hero__rail-num">V</span>
            <span class="dg-hero__rail-body">
              <strong>Admin-runbooks</strong>
              <small>Site Intelligence · Vekst-harness</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">3 runbooks</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>≈ 24 min</span>
              </span>
            </span>
          </a>
        </li>
        <li>
          <a href="/api-referanse/">
            <span class="dg-hero__rail-num">VI</span>
            <span class="dg-hero__rail-body">
              <strong>API-referanse</strong>
              <small>Public · Audits · Content</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">12 endepunkter</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>OpenAPI 3.1</span>
              </span>
            </span>
          </a>
        </li>
        <li>
          <a href="/compliance/">
            <span class="dg-hero__rail-num">VII</span>
            <span class="dg-hero__rail-body">
              <strong>Compliance</strong>
              <small>GDPR · ISO 27001 · NSM · SSA-L</small>
              <span class="dg-hero__rail-meta">
                <span class="dg-hero__rail-pages">4 kapitler</span>
                <span class="dg-hero__rail-sep" aria-hidden="true">·</span>
                <span>≈ 24 min</span>
              </span>
            </span>
          </a>
        </li>
      </ol>

      <section class="dg-hero__links" aria-labelledby="dg-links-heading">
        <p class="dg-hero__links-kicker" id="dg-links-heading">VIKTIGE LENKER</p>
        <ul class="dg-hero__links-list">
          <li>
            <a href="https://digilist.no/" target="_blank" rel="noopener">
              <span class="dg-hero__links-glyph" aria-hidden="true">↗</span>
              <span class="dg-hero__links-body">
                <strong>digilist.no</strong>
                <small>Hovedplattformen — markedsføring &amp; produkt</small>
              </span>
            </a>
          </li>
          <li>
            <a href="https://digilist.no/admin/intelligence" target="_blank" rel="noopener">
              <span class="dg-hero__links-glyph" aria-hidden="true">↗</span>
              <span class="dg-hero__links-body">
                <strong>Admin Intelligence</strong>
                <small>Vekst-harness, audits, content-pipeline</small>
              </span>
            </a>
          </li>
          <li>
            <a href="/api-referanse/" >
              <span class="dg-hero__links-glyph" aria-hidden="true">§</span>
              <span class="dg-hero__links-body">
                <strong>OpenAPI 3.1-spec</strong>
                <small>12 endepunkter · chat · audits · content</small>
              </span>
            </a>
          </li>
          <li>
            <a href="https://status.digilist.no/" target="_blank" rel="noopener">
              <span class="dg-hero__links-glyph" aria-hidden="true">●</span>
              <span class="dg-hero__links-body">
                <strong>Driftsstatus</strong>
                <small>Sanntid · oppetid 99,98 % siste 90 dager</small>
              </span>
            </a>
          </li>
          <li>
            <a href="https://github.com/xalatechnologies/booking-brilliance" target="_blank" rel="noopener">
              <span class="dg-hero__links-glyph" aria-hidden="true">↗</span>
              <span class="dg-hero__links-body">
                <strong>GitHub</strong>
                <small>Kildekode &amp; changelog</small>
              </span>
            </a>
          </li>
          <li>
            <a href="mailto:hei@digilist.no">
              <span class="dg-hero__links-glyph" aria-hidden="true">✉</span>
              <span class="dg-hero__links-body">
                <strong>hei@digilist.no</strong>
                <small>Spørsmål, demo, partnerskap</small>
