---
/**
 * Editorial theme toggle — mirrors src/components/ThemeToggle.tsx of the
 * marketing site exactly:
 *   - 40×40 square button with rounded-sm (2px) border-hairline-strong
 *   - Sun icon visible in light mode, Moon icon visible in dark mode
 *   - Both icons stacked, swap via rotate+scale animation
 *
 * Reads/writes Starlight's `starlight-theme` localStorage key (light|dark|auto)
 * and updates document.documentElement.dataset.theme so it integrates with
 * Starlight's runtime + our CSS without a separate theme system.
 */
---

<button
  type="button"
  class="dg-theme-toggle"
  aria-label="Bytt tema"
  data-dg-theme-toggle
>
  <!-- Sun (light mode) -->
  <svg
    class="dg-theme-toggle__icon dg-theme-toggle__icon--sun"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <!-- Moon (dark mode) -->
  <svg
    class="dg-theme-toggle__icon dg-theme-toggle__icon--moon"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
  <span class="sr-only">Bytt tema</span>
</button>

<script is:inline>
  (function () {
    const KEY = "starlight-theme";
    const root = document.documentElement;

    function applied() {
      // Starlight resolves "auto" → light/dark at runtime; we want the
      // applied theme, not the stored preference. Read the data-attr after
      // Starlight's own bootstrap script ran.
      return root.dataset.theme === "dark" ? "dark" : "light";
    }

    function set(theme) {
      try { localStorage.setItem(KEY, theme); } catch (e) {}
      root.dataset.theme = theme;
      // Also flip Starlight's stored picker if the <select> exists.
      const sel = document.querySelector("starlight-theme-select select");
      if (sel) {
        sel.value = theme;
        sel.dispatchEvent(new Event("change", { bubbles: true }));
      }
    }

    document.querySelectorAll("[data-dg-theme-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        set(applied() === "dark" ? "light" : "dark");
      });
    });
  })();
</script>

<style>
  .dg-theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
    width: 2.5rem;
    border: 0.5px solid hsl(var(--rule-strong));
    border-radius: 2px;
    background: transparent;
    color: hsl(var(--ink));
    cursor: pointer;
    transition: background-color var(--dur-quick, 220ms)
      var(--ease-editorial, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .dg-theme-toggle:hover {
    background: hsl(var(--paper-deep));
  }

  .dg-theme-toggle:focus-visible {
    outline: 2px solid hsl(var(--navy));
    outline-offset: 2px;
  }

  .dg-theme-toggle__icon {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
    transition:
      transform var(--dur-normal, 420ms)
        var(--ease-editorial, cubic-bezier(0.22, 1, 0.36, 1)),
      opacity var(--dur-quick, 220ms) ease;
  }

  /* Light mode: show sun, hide moon */
  .dg-theme-toggle__icon--sun {
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
    opacity: 1;
  }
  .dg-theme-toggle__icon--moon {
    transform: translate(-50%, -50%) rotate(90deg) scale(0);
    opacity: 0;
  }

  /* Dark mode: hide sun, show moon */
  :root[data-theme="dark"] .dg-theme-toggle__icon--sun {
    transform: translate(-50%, -50%) rotate(-90deg) scale(0);
    opacity: 0;
  }
  :root[data-theme="dark"] .dg-theme-toggle__icon--moon {
    transform: translate(-50%, -50%) rotate(0deg) scale(1);
    opacity: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
